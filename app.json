{
  "expo": {
    "name": "expo-widgets-test",
    "slug": "expo-widgets-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "expowidgetstest",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schroedernathan.expo-widgets-test"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.schroedernathan.expowidgetstest"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.schroedernathan.expo-widgets-test",
          "enablePushNotifications": true,
          "widgets": [
            {
              "name": "MailWidget",
              "displayName": "Mailbox",
              "description": "Jump straight to Inbox, Starred, Drafts, or Compose — each opens its own screen.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "HydrationWidget",
              "displayName": "Hydration",
              "description": "Log water straight from the home screen and watch the bottle fill.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            },
            {
              "name": "DayArcWidget",
              "displayName": "Day Arc",
              "description": "A living clock that shows how much of your waking day is left.",
              "contentMarginsDisabled": true,
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      "expo-router"
    ]
  }
}
